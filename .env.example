# --- cognee (memory layer) ---
# Simplest setup: one OpenAI key covers cognee's LLM + embeddings.
LLM_API_KEY=sk-...
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
# Embeddings default to OpenAI using LLM_API_KEY; override if needed:
# EMBEDDING_PROVIDER=openai
# EMBEDDING_API_KEY=

# --- REM's voice (chat replies) ---
ANTHROPIC_API_KEY=sk-ant-...
CHAT_MODEL=claude-sonnet-5

# --- frontend origin allowed to call the backend ---
CORS_ORIGINS=http://localhost:3000
