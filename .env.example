# --- cognee (memory layer) ---
# Keep cognee's runtime data under the repo so deployment paths are stable.
# DATA_ROOT_DIRECTORY=.rem/data
# SYSTEM_ROOT_DIRECTORY=.rem/system

# Option A: OpenAI — one key covers cognee's LLM + embeddings
#LLM_API_KEY=sk-...
#LLM_PROVIDER=openai
#LLM_MODEL=gpt-4o-mini

# Option B: OpenRouter (free-tier models available) + local fastembed embeddings
# (Groq also works the same way — just swap the endpoint/model/key below;
# Groq's free tier has a 100k tokens/day cap that's easy to blow through
# during heavy testing, which is why this moved to OpenRouter.)
LLM_PROVIDER=custom
LLM_MODEL=openrouter/openai/gpt-4o-mini
LLM_ENDPOINT=https://openrouter.ai/api/v1
LLM_API_KEY=sk-or-v1-...
LLM_RATE_LIMIT_ENABLED=true
LLM_RATE_LIMIT_REQUESTS=25
LLM_RATE_LIMIT_INTERVAL=60
EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- REM's voice (chat replies, any OpenAI-compatible endpoint) ---
CHAT_BASE_URL=https://openrouter.ai/api/v1
CHAT_API_KEY=sk-or-v1-...
CHAT_MODEL=openai/gpt-4o-mini

# --- frontend origin allowed to call the backend ---
CORS_ORIGINS=http://localhost:3000

# --- optional: Cognee Cloud long-term archive (push after every sleep) ---
# COGNEE_SERVICE_URL=https://tenant-<your-tenant-id>.aws.cognee.ai
# COGNEE_API_KEY=<your-cloud-api-key>
